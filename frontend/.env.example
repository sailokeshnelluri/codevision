# ─── CodeVision Frontend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.

# Backend API URL
# In development the Vite proxy forwards /api → localhost:8000, so leave this as-is.
# In production set it to your deployed backend URL, e.g. https://codevision-api.onrender.com
VITE_API_URL=/api
