# ─── CodeVision Backend Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/codevision

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Judge0 (Code Execution) ──────────────────────────────────────────────────
# Sign up at https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# ── AI (use Anthropic OR OpenAI — Anthropic preferred) ───────────────────────
# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (fallback if Anthropic key not set): https://platform.openai.com
OPENAI_API_KEY=sk-...

# ── CORS (comma-separated allowed origins) ───────────────────────────────────
# Add your Vercel frontend URL here
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","https://your-app.vercel.app"]
